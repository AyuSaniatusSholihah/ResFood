generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id            Int      @id @default(autoincrement())
  nama          String   @db.VarChar(100)
  email         String   @unique @db.VarChar(150)
  no_telp       String?  @db.VarChar(20)
  password_hash String   @db.VarChar(255)
  role          String   @db.VarChar(10)
  poin          Int?
  badge         String?  @db.VarChar(100)
  carbon_score  Float?
  created_at    DateTime @default(now())

  // Relations
  makanan_disediakan Makanan[]      @relation("PenyediaMakanan")
  transaksi_dipesan  Transaksi[]    @relation("PemesanTransaksi")
  review_diberikan   ReviewRating[] @relation("PemesanReview")
  review_diterima    ReviewRating[] @relation("PenyediaReview")
  carbon_logs        CarbonLog[]
  poin_rewards       PoinReward[]
  notifikasi         Notifikasi[]

  @@map("users")
}

model Makanan {
  id             Int      @id @default(autoincrement())
  penyedia_id    Int
  nama           String   @db.VarChar(150)
  deskripsi      String?  @db.Text
  foto           String?  @db.VarChar(255)
  harga_asli     Decimal  @db.Decimal(10, 2)
  harga_platform Decimal  @db.Decimal(10, 2)
  jalur          String   @db.VarChar(1)
  tgl_expired    DateTime @db.Date
  stok           Int
  status         String   @db.VarChar(30)
  created_at     DateTime @default(now())

  // Relations
  penyedia    User        @relation("PenyediaMakanan", fields: [penyedia_id], references: [id])
  transaksi   Transaksi[]
  carbon_logs CarbonLog[]

  @@map("makanan")
}

model Transaksi {
  id           Int      @id @default(autoincrement())
  makanan_id   Int
  pemesan_id   Int
  tipe_pemesan String   @db.VarChar(15)
  jumlah       Int
  total_bayar  Decimal? @db.Decimal(10, 2)
  status       String   @db.VarChar(20)
  created_at   DateTime @default(now())

  // Relations
  makanan       Makanan        @relation(fields: [makanan_id], references: [id])
  pemesan       User           @relation("PemesanTransaksi", fields: [pemesan_id], references: [id])
  pembayaran    Pembayaran[]
  review_rating ReviewRating[]

  @@map("transaksi")
}

model Pembayaran {
  id           Int      @id @default(autoincrement())
  transaksi_id Int
  metode       String   @db.VarChar(20)
  jumlah       Decimal  @db.Decimal(10, 2)
  status       String   @db.VarChar(10)
  created_at   DateTime @default(now())

  // Relations
  transaksi Transaksi @relation(fields: [transaksi_id], references: [id])

  @@map("pembayaran")
}

model ReviewRating {
  id           Int      @id @default(autoincrement())
  transaksi_id Int
  pemesan_id   Int
  penyedia_id  Int
  rating       Int
  komentar     String?  @db.Text
  created_at   DateTime @default(now())

  // Relations
  transaksi Transaksi @relation(fields: [transaksi_id], references: [id])
  pemesan   User      @relation("PemesanReview", fields: [pemesan_id], references: [id])
  penyedia  User      @relation("PenyediaReview", fields: [penyedia_id], references: [id])

  @@map("review_rating")
}

model CarbonLog {
  id               Int      @id @default(autoincrement())
  user_id          Int
  makanan_id       Int
  kg_terselamatkan Float
  co2_berkurang    Float
  created_at       DateTime @default(now())

  // Relations
  user    User    @relation(fields: [user_id], references: [id])
  makanan Makanan @relation(fields: [makanan_id], references: [id])

  @@map("carbon_log")
}

model PoinReward {
  id              Int      @id @default(autoincrement())
  user_id         Int
  jenis_aktivitas String   @db.VarChar(20)
  poin_diperoleh  Int
  keterangan      String?  @db.VarChar(255)
  created_at      DateTime @default(now())

  // Relations
  user User @relation(fields: [user_id], references: [id])

  @@map("poin_reward")
}

model Notifikasi {
  id         Int      @id @default(autoincrement())
  user_id    Int
  judul      String   @db.VarChar(150)
  pesan      String   @db.Text
  is_read    Boolean? @default(false)
  created_at DateTime @default(now())

  // Relations
  user User @relation(fields: [user_id], references: [id])

  @@map("notifikasi")
}

model CommunityChallenge {
  id          Int      @id @default(autoincrement())
  judul       String   @db.VarChar(150)
  deskripsi   String?  @db.Text
  target_kg   Float
  progress_kg Float?
  tgl_mulai   DateTime @db.Date
  tgl_selesai DateTime @db.Date
  status      String   @db.VarChar(10)

  @@map("community_challenge")
}
