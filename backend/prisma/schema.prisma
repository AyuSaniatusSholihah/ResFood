generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Jalur {
  A
  B
  C
}

enum MakananStatus {
  AKTIF
  SELESAI
  DIHAPUS
}

enum TransaksiTipe {
  KONSUMSI
  DAUR_ULANG
}

enum TransaksiStatus {
  MENUNGGU
  AKTIF
  SELESAI
  DIBATALKAN
}

model User {
  id        Int         @id @default(autoincrement())
  nama      String      @db.VarChar(100)
  email     String      @unique @db.VarChar(150)
  password  String      @db.VarChar(255)
  role      Role
  isActive  Boolean     @default(true)
  noTelp    String?     @map("no_telp") @db.VarChar(25)
  kecamatan String?     @db.VarChar(100)
  alamatDetail String?  @map("alamat_detail") @db.VarChar(255)
  namaToko  String?     @map("nama_toko") @db.VarChar(120)
  foto      String?     @db.VarChar(255)
  onboardingTourSeen Boolean @default(false) @map("onboarding_tour_seen")
  onboardingPromptSeen Boolean @default(false) @map("onboarding_prompt_seen")
  createdAt DateTime    @default(now())

  // Relations
  makanan   Makanan[]
  transaksi Transaksi[]

  @@map("users")
}

model Makanan {
  id             Int           @id @default(autoincrement())
  nama           String        @db.VarChar(150)
  deskripsi      String        @db.Text
  foto           String        @db.VarChar(255)
  hargaAsli      Float
  hargaPlatform  Float
  jalur          Jalur
  tglExpired     DateTime
  stok           Int
  status         MakananStatus
  createdAt      DateTime      @default(now())

  // Relations
  penyediaId     Int
  penyedia       User          @relation(fields: [penyediaId], references: [id])
  transaksi      Transaksi[]

  @@map("makanan")
}

model Transaksi {
  id         Int             @id @default(autoincrement())
  jumlah     Int
  totalBayar Float
  tipe       TransaksiTipe
  buktiBayar String?         @db.VarChar(255)
  status     TransaksiStatus
  metode     String          @default("QRIS") @db.VarChar(50)
  createdAt  DateTime        @default(now())

  // Relations
  makananId  Int
  makanan    Makanan         @relation(fields: [makananId], references: [id])
  pemesanId  Int
  pemesan    User            @relation(fields: [pemesanId], references: [id])

  @@map("transaksi")
}
